# OpenEO backend (default: CDSE)
OPENEO_BACKEND_URL=https://openeo.dataspace.copernicus.eu

# STAC API (default: CDSE STAC)
STAC_API_URL=https://catalogue.dataspace.copernicus.eu/stac

# OpenEO access token (get via: openeo-auth oidc-device CDSE)
# Leave empty for unauthenticated (read-only) access
OPENEO_TOKEN=
